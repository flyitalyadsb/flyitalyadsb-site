---
import { typesByCategory, fullName, aircraftTypes } from '../data/aircraftTypes';
import { categoryLabel, type Lang } from '../lib/aircraft-content';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props as Props;
const isEn = lang === 'en';
const base = isEn ? '/en' : '';
const groups = typesByCategory();

const t = isEn
  ? {
      kicker: 'Aircraft',
      h1: 'Aircraft types — live tracking',
      lead: `From airliners to military aircraft tracked via MLAT: pick a type to see its specifications and how many FlyItalyADSB is following over Italy right now. ${aircraftTypes.length} types, identified by their ICAO type code.`,
    }
  : {
      kicker: 'Aeromobili',
      h1: 'Tipi di aeromobile — tracciamento in tempo reale',
      lead: `Dai jet di linea ai velivoli militari tracciati via MLAT: scegli un tipo per vederne le caratteristiche e quanti ne sta seguendo ora FlyItalyADSB sull'Italia. ${aircraftTypes.length} tipi, identificati dal loro codice ICAO.`,
    };
---

<div class="pt-24 pb-20 px-6 sm:px-12 lg:px-20 max-w-7xl mx-auto">

  <div class="mb-14">
    <p class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-3">{t.kicker}</p>
    <h1 class="text-4xl font-bold text-slate-100 mb-4">{t.h1}</h1>
    <p class="text-slate-400 max-w-3xl leading-relaxed">{t.lead}</p>
  </div>

  <div class="space-y-12">
    {groups.map((g) => (
      <section>
        <h2 class="text-sm font-semibold text-slate-300 uppercase tracking-wider mb-4 pb-2 border-b" style="border-color:#1e3048">{categoryLabel(g.category, lang)}</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {g.items.map((a) => (
            <a href={`${base}/aeromobili/${a.slug}`} class="block p-5 rounded-xl border no-underline group transition-all hover:border-sky-400/30" style="background:#0f1929;border-color:#1e3048">
              <div class="flex items-center justify-between gap-3 mb-2">
                <span class="text-slate-100 font-semibold text-sm group-hover:text-white transition-colors">{fullName(a)}</span>
                <span class="text-xs font-mono text-slate-500 shrink-0">{a.code}</span>
              </div>
              <p class="text-xs text-slate-500 leading-relaxed line-clamp-2">{isEn ? a.blurbEn : a.blurbIt}</p>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>

</div>
